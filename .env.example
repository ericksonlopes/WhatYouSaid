# Application configuration
APP__ENV=production
APP__LIST_LOG_LEVELS=INFO,WARNING,ERROR,CRITICAL
MODEL_EMBEDDING__NAME=BAAI/bge-m3

# Vector & SQL configuration
VECTOR__STORE_TYPE=faiss
VECTOR__COLLECTION_NAME_CHUNKS=chunks

VECTOR__WEAVIATE_HOST=localhost
VECTOR__WEAVIATE_PORT=8081
VECTOR__WEAVIATE_API_KEY=
VECTOR__WEAVIATE_GRPC_PORT=50051

VECTOR__CHROMA_HOST=localhost
VECTOR__CHROMA_PORT=8000

# SQL connection (Nested under VECTOR)
# You can provide individual fields:
VECTOR__SQL__TYPE=sqlite
VECTOR__SQL__HOST=
VECTOR__SQL__PORT=
VECTOR__SQL__USER=
VECTOR__SQL__PASSWORD=
VECTOR__SQL__DATABASE=

# OR a direct connection string (overrides fields above):
# VECTOR__SQL__URL=postgresql://user:pass@localhost:5432/dbname

